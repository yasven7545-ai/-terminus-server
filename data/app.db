CREATE TABLE users (  id INTEGER PRIMARY KEY AUTOINCREMENT,  username TEXT UNIQUE NOT NULL,  password_hash TEXT NOT NULL);CREATE TABLE metrics (  id INTEGER PRIMARY KEY AUTOINCREMENT,  name TEXT NOT NULL,  value REAL NOT NULL,  timestamp DATETIME DEFAULT CURRENT_TIMESTAMP);CREATE TABLE sln_data (  id INTEGER PRIMARY KEY AUTOINCREMENT,  node TEXT,  status TEXT,  last_seen DATETIME);